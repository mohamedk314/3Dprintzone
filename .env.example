# =============================================================================
# 3Dprintzone — environment variables template
#
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Then fill in real values. NEVER commit real secrets.
# Production secrets must be set in your hosting provider's dashboard
# (Railway, Vercel, etc.), not in this file.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string used by Prisma. Must start with `postgresql://`.
# Local example:  postgresql://postgres:password@127.0.0.1:5432/3dprintzone
# Production:     use the connection string from your managed PostgreSQL
#                 provider (Neon / Prisma Postgres / Supabase via the Vercel
#                 Marketplace). Keep `sslmode=require` for managed providers.
#
# Vercel: Project → Settings → Environment Variables → add DATABASE_URL for
# Production and Preview (installing a Marketplace database usually injects it
# automatically), then redeploy.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?sslmode=require"


# -----------------------------------------------------------------------------
# Public app URL (required)
# -----------------------------------------------------------------------------
# Used by metadata, sitemap.xml, robots.txt and Open Graph tags.
# Local:       http://localhost:3000
# Production:  https://yourdomain.com  (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Canonical site URL for SEO (metadata, sitemap, robots, JSON-LD).
# Takes precedence over NEXT_PUBLIC_APP_URL when set. No trailing slash.
NEXT_PUBLIC_SITE_URL="https://3dprintzone-eg.com"

# RAYK brand subdomain. When set, RAYK pages canonicalize to this origin,
# sitemap entries for RAYK use it, and the proxy serves the /rayk/* routes
# from clean root-level URLs on this host (rayk.../shop -> /rayk/shop).
# Leave empty to keep path-based /rayk/* URLs only (e.g. local dev).
NEXT_PUBLIC_RAYK_SITE_URL="https://rayk.3dprintzone-eg.com"


# -----------------------------------------------------------------------------
# Admin authentication (required)
# -----------------------------------------------------------------------------
# JWT_SECRET: long random string (≥ 32 chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string-at-least-48-bytes"

# Super-admin email (required for admin login). This account is auto-created
# with role super_admin on first OTP request and cannot be locked out.
# Comparison is trimmed and case-insensitive.
SUPER_ADMIN_EMAIL="owner@example.com"

# Optional: comma-separated additional admin emails. Each is auto-created with
# role "admin" on first OTP request. A deactivated admin stays locked out even
# if listed here.
ADMIN_ALLOWED_EMAILS="admin1@example.com,admin2@example.com"

# DEPRECATED: ADMIN_EMAIL is a legacy alias for SUPER_ADMIN_EMAIL and is only
# used if SUPER_ADMIN_EMAIL is unset. Prefer SUPER_ADMIN_EMAIL.
# ADMIN_EMAIL="owner@example.com"

# Minutes an OTP code stays valid (minimum 5 enforced server-side).
ADMIN_OTP_EXPIRES_MINUTES="10"

# Days an admin session/JWT stays valid.
ADMIN_SESSION_EXPIRES_DAYS="7"


# -----------------------------------------------------------------------------
# Email / SMTP (required for admin OTP login and customer notifications)
# -----------------------------------------------------------------------------
# Gmail example uses a 16-char Google App Password, NOT your Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-mailer@gmail.com"
SMTP_PASS="your-16-char-app-password"

# "From" header. Format: "Display Name <email@domain.com>"
SMTP_FROM="3Dprintzone <your-mailer@gmail.com>"


# -----------------------------------------------------------------------------
# Cloudflare R2 — image/file storage (optional)
# -----------------------------------------------------------------------------
# Used for admin uploads of product images. If empty, the upload routes
# return an error but the rest of the site works normally.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public bucket URL, e.g. https://pub-xxxx.r2.dev or your custom CDN domain.
R2_PUBLIC_URL=""


# -----------------------------------------------------------------------------
# Paymob — online card payments (optional)
# -----------------------------------------------------------------------------
# Leave empty to disable card payments. Cash on Delivery (COD) works
# without these. Get credentials from your Paymob dashboard.
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""
PAYMOB_HMAC_SECRET=""
