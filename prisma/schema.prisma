generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  super_admin
  admin
}

enum OrderStatus {
  delivered
  ordered_cod
  ordered_paid
  canceled
}

enum PaymentMethod {
  cod
  paymob
}

enum ProductType {
  physical
  digital
  service
}

enum CustomRequestType {
  architecture
  gift
  dental
  mechanical
}

enum CustomRequestStatus {
  pending
  reviewed
  approved
  rejected
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum ShipmentStatus {
  pending
  confirmed
  packed
  shipped
  out_for_delivery
  delivered
  returned
  canceled
}

model AdminUser {
  id        String         @id @default(cuid())
  email     String         @unique
  role      AdminRole      @default(admin)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  otpCodes  AdminOtpCode[]
  sessions  AdminSession[]

  @@index([role])
}

model AdminOtpCode {
  id          String    @id @default(cuid())
  adminUserId String
  codeHash    String
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model AdminSession {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  brand       String    @default("3dprintzone")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([brand])
}

model Product {
  id                String        @id @default(cuid())
  categoryId        String
  name              String
  slug              String        @unique
  shortDescription  String?       @db.Text
  description       String?       @db.LongText
  sku               String?       @unique
  price             Decimal       @db.Decimal(10, 2)
  compareAtPrice    Decimal?      @db.Decimal(10, 2)
  stockQty          Int           @default(0)
  lowStockThreshold       Int           @default(3)
  lowStockAlertSentAt     DateTime?
  outOfStockAlertSentAt   DateTime?
  productType             ProductType   @default(physical)
  isActive                Boolean       @default(true)
  isFeatured              Boolean       @default(false)
  forceShippingDiscussion Boolean       @default(false)
  brand                   String        @default("3dprintzone")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  category          Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images            ProductImage[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  orderItems        OrderItem[]
  reviews           Review[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isFeatured])
  @@index([productType])
  @@index([brand])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String
  brand     String     @default("3dprintzone")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]

  @@unique([sessionId, brand])
  @@index([sessionId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  qty       Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Wishlist {
  id        String         @id @default(cuid())
  sessionId String
  brand     String         @default("3dprintzone")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  items     WishlistItem[]

  @@unique([sessionId, brand])
  @@index([sessionId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())

  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
}

model ShippingZone {
  id               String   @id @default(cuid())
  name             String
  governorates     String   @db.Text
  priceOverride    Decimal  @db.Decimal(10, 2)
  estimatedDaysMin Int      @default(1)
  estimatedDaysMax Int      @default(3)
  isActive         Boolean  @default(true)
  brand            String   @default("both")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders           Order[]

  @@index([isActive])
  @@index([brand])
}

model ShippingMethod {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  estimatedDays Int      @default(3)
  isActive      Boolean  @default(true)
  brand         String   @default("both")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]

  @@index([isActive])
  @@index([brand])
}

model Order {
  id                String          @id @default(cuid())
  orderRef          String          @unique
  customerName      String
  email             String
  phone             String
  status            OrderStatus
  paymentMethod     PaymentMethod
  subtotal          Decimal         @db.Decimal(10, 2)
  shippingFee       Decimal         @default(0.00) @db.Decimal(10, 2)
  total             Decimal         @db.Decimal(10, 2)
  notes             String?         @db.Text
  brand             String          @default("3dprintzone")
  shipmentStatus    ShipmentStatus?
  trackingNumber    String?
  courierName       String?
  estimatedDelivery DateTime?
  shippingMethodId  String?
  shippingZoneId    String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  address           Address?
  items             OrderItem[]
  shippingMethod    ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  shippingZone      ShippingZone?   @relation(fields: [shippingZoneId], references: [id])

  @@index([status])
  @@index([shipmentStatus])
  @@index([paymentMethod])
  @@index([createdAt])
  @@index([email])
  @@index([phone])
  @@index([brand])
}

model Address {
  id           String   @id @default(cuid())
  orderId      String   @unique
  governorate  String
  city         String
  area         String?
  addressLine1 String
  addressLine2 String?
  building     String?
  floor        String?
  apartment    String?
  landmark     String?
  createdAt    DateTime @default(now())

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String?
  qty         Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  lineTotal   Decimal  @db.Decimal(10, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model CustomRequest {
  id           String              @id @default(cuid())
  fullName     String
  email        String
  phone        String
  requestType  CustomRequestType
  description  String              @db.LongText
  referenceUrl String?
  status       CustomRequestStatus @default(pending)
  adminNotes   String?             @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([requestType])
  @@index([status])
  @@index([createdAt])
}

model CustomerOtpCode {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model CustomerSession {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Review {
  id        String       @id @default(cuid())
  productId String
  email     String
  name      String
  rating    Int
  body      String?      @db.Text
  status    ReviewStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
  @@index([email])
}